<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Categories - ONNIEONE NEWS</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin-enhanced.css">
</head>
<body>
    <div class="admin-wrapper">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="sidebar-header">
                <h2><span>ONNIEONE</span> NEWS</h2>
                <p>Admin Panel</p>
            </div>
            
            <div class="sidebar-menu">
                <div class="menu-category">MAIN</div>
                <a href="/admin/dashboard" class="menu-item">
                    <i class="fas fa-tachometer-alt"></i> Dashboard
                </a>
                <a href="/admin/news" class="menu-item">
                    <i class="fas fa-newspaper"></i> All News
                </a>
                <a href="/admin/news/add" class="menu-item">
                    <i class="fas fa-plus-circle"></i> Add News
                </a>
                
                <div class="menu-category">CONTENT</div>
                <a href="/admin/categories" class="menu-item active">
                    <i class="fas fa-list"></i> Categories
                </a>
                <a href="/admin/featured" class="menu-item">
                    <i class="fas fa-star"></i> Featured Articles
                </a>
                <a href="/admin/breaking" class="menu-item">
                    <i class="fas fa-bolt"></i> Breaking News
                </a>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Top Bar -->
            <div class="top-bar">
                <div class="page-title">
                    <h1>Categories</h1>
                    <p>Manage your content categories</p>
                </div>
                <div class="user-info">
                    <div class="user-avatar">
                        <%= user.full_name ? user.full_name.charAt(0).toUpperCase() : 'A' %>
                    </div>
                    <a href="/admin/logout" class="btn-logout">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                </div>
            </div>

            <!-- Categories List -->
            <div class="content-card">
                <div class="card-header">
                    <h2><i class="fas fa-list"></i> All Categories</h2>
                    <button onclick="showAddModal()" class="btn btn-primary">
                        <i class="fas fa-plus-circle"></i> Add Category
                    </button>
                </div>
                
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Icon</th>
                                <th>Name (EN)</th>
                                <th>Name (FR)</th>
                                <th>Name (RW)</th>
                                <th>Slug</th>
                                <th>Articles</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (categories && categories.length > 0) { %>
                                <% categories.forEach(cat => { %>
                                    <tr>
                                        <td>#<%= cat.id %></td>
                                        <td><i class="<%= cat.icon || 'fas fa-tag' %>" style="color: #dc2626;"></i></td>
                                        <td><strong><%= cat.name_en %></strong></td>
                                        <td><%= cat.name_fr || '-' %></td>
                                        <td><%= cat.name_rw || '-' %></td>
                                        <td><code><%= cat.slug %></code></td>
                                        <td><span class="status-badge status-published"><%= cat.news_count || 0 %></span></td>
                                        <td class="action-buttons">
                                            <button onclick="editCategory(<%= cat.id %>)" class="btn btn-success btn-sm">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button onclick="deleteCategory(<%= cat.id %>)" class="btn btn-danger btn-sm">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="8" style="text-align: center; padding: 30px;">
                                        <i class="fas fa-tags" style="font-size: 3rem; color: #ddd; margin-bottom: 15px;"></i>
                                        <p>No categories found.</p>
                                        <button onclick="showAddModal()" class="btn btn-primary btn-sm">Add your first category</button>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Category Modal -->
    <div id="addModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-plus-circle"></i> Add New Category</h3>
                <span class="close" onclick="hideAddModal()">&times;</span>
            </div>
            <form onsubmit="addCategory(event)">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <div class="form-group">
                    <label>Name (English) *</label>
                    <input type="text" id="name_en" class="form-control" required>
                </div>
                <div class="form-group">
                    <label>Name (French)</label>
                    <input type="text" id="name_fr" class="form-control">
                </div>
                <div class="form-group">
                    <label>Name (Kinyarwanda)</label>
                    <input type="text" id="name_rw" class="form-control">
                </div>
                <div class="form-group">
                    <label>Slug (URL)</label>
                    <input type="text" id="slug" class="form-control" placeholder="leave empty to auto-generate">
                </div>
                <div class="form-group">
                    <label>Icon (Font Awesome class)</label>
                    <input type="text" id="icon" class="form-control" placeholder="fas fa-tag">
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea id="description" class="form-control" rows="3"></textarea>
                </div>
                <div class="form-group">
                    <label>Color</label>
                    <input type="color" id="color" class="form-control" value="#dc2626">
                </div>
                <button type="submit" class="btn btn-primary">Add Category</button>
                <button type="button" class="btn btn-outline" onclick="hideAddModal()">Cancel</button>
            </form>
        </div>
    </div>

    <script>
        function showAddModal() {
            document.getElementById('addModal').style.display = 'block';
        }
        
        function hideAddModal() {
            document.getElementById('addModal').style.display = 'none';
        }
        
        function addCategory(event) {
            event.preventDefault();
            
            const data = {
                name_en: document.getElementById('name_en').value,
                name_fr: document.getElementById('name_fr').value,
                name_rw: document.getElementById('name_rw').value,
                slug: document.getElementById('slug').value,
                icon: document.getElementById('icon').value,
                description: document.getElementById('description').value,
                color: document.getElementById('color').value
            };
            
            fetch('/admin/categories/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'CSRF-Token': '<%= typeof csrfToken !== \'undefined\' ? csrfToken : \'\' %>' },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error adding category');
                }
            });
        }
        
        function deleteCategory(id) {
            if (confirm('Are you sure you want to delete this category? Articles in this category will be uncategorized.')) {
                fetch('/admin/categories/delete/' + id, { method: 'POST', headers: { 'CSRF-Token': '<%= typeof csrfToken !== \'undefined\' ? csrfToken : \'\' %>' } })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            location.reload();
                        } else {
                            alert('Error deleting category');
                        }
                    });
            }
        }
    </script>
</body>
</html>
