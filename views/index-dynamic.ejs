<!DOCTYPE html>
<html lang="<%= lang || 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= settings.site_title || 'ONNIEONE NEWS' %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #f5f5f5; }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 15px; }
        
        /* Top Bar */
        .top-bar {
            background: #000;
            color: white;
            padding: 8px 0;
            font-size: 0.85rem;
        }
        .top-bar .container {
            display: flex;
            justify-content: space-between;
        }
        .top-links a {
            color: #ccc;
            text-decoration: none;
            margin-right: 15px;
        }
        .top-links a:hover { color: #dc2626; }
        
        /* Header */
        .main-header {
            background: #dc2626;
            padding: 20px 0;
        }
        .main-header .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo {
            font-size: 2.5rem;
            font-weight: 900;
            color: white;
            text-decoration: none;
        }
        .logo span { color: #ffd700; }
        
        /* Navigation */
        .nav-bar {
            background: #222;
            border-bottom: 3px solid #dc2626;
        }
        .nav-menu {
            display: flex;
            list-style: none;
        }
        .nav-item a {
            display: block;
            padding: 15px 20px;
            color: white;
            text-decoration: none;
            border-right: 1px solid #444;
        }
        .nav-item a:hover { background: #dc2626; }
        
        /* Breaking News */
        .breaking-news {
            background: white;
            border-bottom: 1px solid #ddd;
            padding: 10px 0;
        }
        .breaking-content {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .breaking-label {
            background: #dc2626;
            color: white;
            padding: 5px 15px;
            font-weight: bold;
        }
        
        /* Main Layout */
        .main-layout {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 20px;
            margin: 20px 0;
        }
        
        /* Featured Article */
        .featured-article {
            background: white;
            border: 1px solid #ddd;
            margin-bottom: 20px;
        }
        .featured-image {
            height: 300px;
            overflow: hidden;
        }
        .featured-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .featured-content { padding: 20px; }
        .featured-category {
            color: #dc2626;
            font-weight: bold;
            text-transform: uppercase;
        }
        .featured-title {
            font-size: 1.8rem;
            margin: 10px 0;
        }
        .featured-title a {
            color: #000;
            text-decoration: none;
        }
        .featured-title a:hover { color: #dc2626; }
        
        /* Article Grid */
        .article-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        .article-card {
            background: white;
            border: 1px solid #ddd;
        }
        .article-image {
            height: 150px;
            overflow: hidden;
        }
        .article-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .article-content { padding: 15px; }
        .article-category {
            color: #dc2626;
            font-size: 0.8rem;
            font-weight: bold;
            text-transform: uppercase;
        }
        .article-title {
            font-size: 1.1rem;
            margin: 5px 0;
        }
        .article-title a {
            color: #000;
            text-decoration: none;
        }
        .article-title a:hover { color: #dc2626; }
        
        /* Pagination */
        .pagination {
            margin: 30px 0;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }
        .page-link {
            color: #333;
            text-decoration: none;
            font-weight: 600;
            padding: 5px 10px;
        }
        .page-link.active { color: #dc2626; }
        .separator { color: #ccc; }
        
        /* Sidebar */
        .sidebar {
            background: white;
            border: 1px solid #ddd;
            padding: 20px;
        }
        .sidebar-title {
            color: #000;
            font-size: 1.3rem;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #dc2626;
        }
        
        /* Popular List */
        .popular-list { list-style: none; }
        .popular-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 10px 0;
            border-bottom: 1px solid #eee;
        }
        .popular-rank {
            width: 30px;
            height: 30px;
            background: #000;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }
        
        /* Video Section */
        .video-thumbnail {
            position: relative;
            margin-bottom: 15px;
        }
        .video-thumbnail img {
            width: 100%;
            height: 180px;
            object-fit: cover;
        }
        .play-icon {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 50px;
            height: 50px;
            background: #dc2626;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            cursor: pointer;
        }
        
        /* Fun Facts */
        .fun-facts {
            background: #f9f9f9;
            padding: 20px;
            border-left: 4px solid #dc2626;
        }
        .fact-item {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 15px;
        }
        .fact-item i {
            font-size: 1.5rem;
            color: #dc2626;
            width: 30px;
        }
        
        /* Footer */
        .site-footer {
            background: #000;
            color: white;
            padding: 40px 0 20px;
            margin-top: 40px;
        }
        .footer-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 30px;
        }
        .footer-col h4 { margin-bottom: 20px; }
        .footer-col ul { list-style: none; }
        .footer-col li { margin-bottom: 10px; }
        .footer-col a {
            color: #999;
            text-decoration: none;
        }
        .footer-col a:hover { color: #dc2626; }
        .footer-bottom {
            border-top: 1px solid #333;
            padding-top: 20px;
            text-align: center;
            color: #666;
        }
    </style>
</head>
<body>
    <!-- Top Bar -->
    <div class="top-bar">
        <div class="container">
            <div class="top-links">
                <% if (topLinks && topLinks.length > 0) { 
                    topLinks.forEach(link => { %>
                    <a href="<%= link.url %>"><%= link['title_' + (lang || 'en')] || link.title_en %></a>
                <% }); } %>
            </div>
            <div class="date">
                <i class="far fa-calendar"></i> 
                <%= new Date().toLocaleDateString('rw-RW', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
            </div>
        </div>
    </div>

    <!-- Main Header -->
    <div class="main-header">
        <div class="container">
            <a href="/" class="logo">
                <%= settings.site_name || 'ONNIEONE' %> <span><%= settings.site_suffix || 'NEWS' %></span>
            </a>
        </div>
    </div>

    <!-- Navigation -->
    <div class="nav-bar">
        <div class="container">
            <ul class="nav-menu">
                <% if (menus && menus.length > 0) { 
                    menus.sort((a,b) => a.order_position - b.order_position).forEach(menu => { %>
                    <li class="nav-item">
                        <a href="<%= menu.url %>">
                            <% if(menu.icon) { %><i class="<%= menu.icon %>"></i> <% } %>
                            <%= menu['title_' + (lang || 'en')] || menu.title_en %>
                        </a>
                    </li>
                <% }); } %>
            </ul>
        </div>
    </div>

    <!-- Breaking News -->
    <% if (breakingNews && breakingNews.length > 0) { 
        breakingNews.filter(n => n.is_active).forEach(news => { %>
    <div class="breaking-news">
        <div class="container">
            <div class="breaking-content">
                <span class="breaking-label">CYAMUNARA</span>
                <div class="breaking-ticker">
                    <a href="<%= news.url %>"><%= news['content_' + (lang || 'en')] || news.content_en %></a>
                </div>
            </div>
        </div>
    </div>
    <% }); } %>

    <!-- Main Content -->
    <div class="container">
        <div class="main-layout">
            <!-- Left Column -->
            <div class="main-content">
                <!-- Featured Article -->
                <% if (featured && featured.length > 0) { 
                    featured.filter(f => f.is_active).sort((a,b) => a.order_position - b.order_position).forEach(feature => { %>
                <div class="featured-article">
                    <div class="featured-image">
                        <img src="<%= feature.image_url || 'https://images.unsplash.com/photo-1495020689067-958852a7765e?w=800' %>" alt="<%= feature['title_' + (lang || 'en')] || feature.title_en %>">
                    </div>
                    <div class="featured-content">
                        <span class="featured-category"><%= feature.category || 'CYAMUNARA' %></span>
                        <h1 class="featured-title">
                            <a href="/article/<%= feature.article_id %>"><%= feature['title_' + (lang || 'en')] || feature.title_en %></a>
                        </h1>
                        <p class="featured-excerpt"><%= feature['excerpt_' + (lang || 'en')] || feature.excerpt_en %></p>
                    </div>
                </div>
                <% }); } %>

                <!-- Article Grid -->
                <div class="article-grid">
                    <% if (recentArticles && recentArticles.length > 0) { 
                        recentArticles.slice(0,4).forEach(article => { %>
                    <div class="article-card">
                        <div class="article-image">
                            <img src="<%= article.image_url || 'https://images.unsplash.com/photo-1495020689067-958852a7765e?w=400' %>" alt="<%= article['title_' + (lang || 'en')] || article.title_en %>">
                        </div>
                        <div class="article-content">
                            <span class="article-category"><%= article.category_name || 'AMAKURU' %></span>
                            <h3 class="article-title">
                                <a href="/article/<%= article.id %>"><%= article['title_' + (lang || 'en')] || article.title_en %></a>
                            </h3>
                            <div class="article-meta">
                                <i class="far fa-clock"></i> <%= new Date(article.published_at).toLocaleDateString() %>
                            </div>
                        </div>
                    </div>
                    <% }); } %>
                </div>

                <!-- Pagination -->
                <div class="pagination">
                    <a href="?page=1" class="page-link active">1</a>
                    <span class="separator">|</span>
                    <a href="?page=2" class="page-link">2</a>
                    <span class="separator">|</span>
                    <a href="?page=3" class="page-link">3</a>
                    <span class="separator">|</span>
                    <a href="?page=4" class="page-link">4</a>
                    <span class="separator">|</span>
                    <a href="?page=5" class="page-link">5</a>
                </div>
            </div>

            <!-- Right Column - Sidebar -->
            <div class="sidebar">
                <!-- Popular News -->
                <h3 class="sidebar-title">
                    <i class="fas fa-fire"></i> Inkuru zamamaza
                </h3>
                <div class="popular-list">
                    <% if (popularNews && popularNews.length > 0) { 
                        popularNews.slice(0,5).forEach((news, index) => { %>
                    <div class="popular-item">
                        <span class="popular-rank"><%= index + 1 %></span>
                        <div class="popular-content">
                            <a href="/article/<%= news.id %>"><%= news['title_' + (lang || 'en')] || news.title_en %></a>
                        </div>
                    </div>
                    <% }); } %>
                </div>

                <!-- Fun Facts -->
                <h3 class="sidebar-title">
                    <i class="fas fa-lightbulb"></i> Unutima
                </h3>
                <div class="fun-facts">
                    <% if (funFacts && funFacts.length > 0) { 
                        funFacts.filter(f => f.is_active).sort((a,b) => a.order_position - b.order_position).forEach(fact => { %>
                    <div class="fact-item">
                        <i class="<%= fact.icon || 'fas fa-info-circle' %>"></i>
                        <p><%= fact['fact_' + (lang || 'en')] || fact.fact_en %></p>
                    </div>
                    <% }); } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="container">
            <div class="footer-grid">
                <% if (footerLinks && footerLinks.length > 0) { 
                    const categories = {};
                    footerLinks.forEach(link => {
                        const cat = link['category_' + (lang || 'en')] || link.category_en;
                        if (!categories[cat]) categories[cat] = [];
                        categories[cat].push(link);
                    });
                    Object.keys(categories).forEach(category => { %>
                <div class="footer-col">
                    <h4><%= category %></h4>
                    <ul>
                        <% categories[category].forEach(link => { %>
                        <li>
                            <a href="<%= link.url %>">
                                <% if(link.icon) { %><i class="<%= link.icon %>"></i> <% } %>
                                <%= link['title_' + (lang || 'en')] || link.title_en %>
                            </a>
                        </li>
                        <% }); %>
                    </ul>
                </div>
                <% }); } %>
            </div>
            <div class="footer-bottom">
                <p>&copy; <%= new Date().getFullYear() %> <%= settings.site_name || 'ONNIEONE NEWS' %>. <%= settings.copyright_text || 'Uburenganzira bwose bwemejwe.' %></p>
            </div>
        </div>
    </footer>
</body>
</html>
