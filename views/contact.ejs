<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - ONNIEONE News</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f5f5f5; }
        .container { max-width: 800px; margin: 0 auto; padding: 0 20px; }
        
        .page-header {
            background: linear-gradient(135deg, #000000 0%, #dc2626 70%, #ffffff 100%);
            color: white; padding: 60px 0; text-align: center;
        }
        .page-header i { font-size: 50px; margin-bottom: 15px; }
        .page-header h1 { font-size: 36px; text-shadow: 2px 2px 0 #dc2626; }
        
        .page-content {
            background: white; border-radius: 16px; padding: 40px; margin: 40px 0;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }
        .page-content h2 { color: #1a1a1a; margin: 30px 0 15px; border-bottom: 3px solid #dc2626; padding-bottom: 10px; }
        .page-content h3 { color: #dc2626; margin: 20px 0 10px; }
        .page-content p { color: #495057; line-height: 1.8; margin-bottom: 15px; }
        .page-content ul { margin-left: 20px; margin-bottom: 20px; }
        .page-content li { color: #495057; margin: 8px 0; }
        
        .btn-primary {
            background: #dc2626; color: white; border: none; padding: 12px 30px;
            border-radius: 30px; font-weight: 600; cursor: pointer; transition: all 0.3s;
        }
        .btn-primary:hover { background: #000; transform: translateY(-2px); }
        
        @media (max-width: 768px) {
            .page-header h1 { font-size: 28px; }
            .page-content { padding: 25px; }
        }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="page-header">
        <div class="container">
            <i class="fas fa-envelope"></i>
            <h1>Contact Us</h1>
        </div>
    </div>

    <div class="container">
        <div class="page-content">
            
            <h2>Get in Touch</h2>
            <p>We'd love to hear from you! Whether you have a news tip, feedback, or just want to say hello, reach out to us through any of the channels below.</p>
            
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 30px; margin: 40px 0;">
                <div style="text-align: center; padding: 30px; background: var(--gray-100); border-radius: 12px; border-left: 4px solid var(--red);">
                    <i class="fas fa-map-marker-alt" style="font-size: 40px; color: var(--red); margin-bottom: 15px;"></i>
                    <h3>Visit Us</h3>
                    <p>KG 7 Ave, Kigali<br>Rwanda</p>
                </div>
                <div style="text-align: center; padding: 30px; background: var(--gray-100); border-radius: 12px; border-left: 4px solid var(--red);">
                    <i class="fas fa-phone" style="font-size: 40px; color: var(--red); margin-bottom: 15px;"></i>
                    <h3>Call Us</h3>
                    <p>+250 788 123 456<br>+250 788 123 457</p>
                </div>
                <div style="text-align: center; padding: 30px; background: var(--gray-100); border-radius: 12px; border-left: 4px solid var(--red);">
                    <i class="fas fa-envelope" style="font-size: 40px; color: var(--red); margin-bottom: 15px;"></i>
                    <h3>Email Us</h3>
                    <p>info@onnieone.com<br>support@onnieone.com</p>
                </div>
                <div style="text-align: center; padding: 30px; background: var(--gray-100); border-radius: 12px; border-left: 4px solid var(--red);">
                    <i class="fas fa-clock" style="font-size: 40px; color: var(--red); margin-bottom: 15px;"></i>
                    <h3>Working Hours</h3>
                    <p>Mon-Fri: 8am - 8pm<br>Sat-Sun: 10am - 6pm</p>
                </div>
            </div>
            
            <h3>Send Us a Message</h3>
            <form style="margin-top: 20px;">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 20px;">
                    <input type="text" placeholder="Your Name" style="padding: 12px; border: 2px solid var(--gray-200); border-radius: 8px;">
                    <input type="email" placeholder="Your Email" style="padding: 12px; border: 2px solid var(--gray-200); border-radius: 8px;">
                </div>
                <input type="text" placeholder="Subject" style="width: 100%; padding: 12px; border: 2px solid var(--gray-200); border-radius: 8px; margin-bottom: 20px;">
                <textarea placeholder="Your Message" rows="5" style="width: 100%; padding: 12px; border: 2px solid var(--gray-200); border-radius: 8px; margin-bottom: 20px;"></textarea>
                <button class="btn btn-primary" style="padding: 12px 40px;">Send Message</button>
            </form>
        
        </div>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>