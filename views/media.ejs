<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Media Library - ONNIEONE Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        .media-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-top: 20px;
        }
        
        .media-item {
            background: var(--pure-white);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: var(--shadow-md);
            transition: all 0.3s;
            border: 1px solid var(--gray-200);
        }
        
        .media-item:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
            border-color: var(--primary-red);
        }
        
        .media-preview {
            height: 150px;
            background-size: cover;
            background-position: center;
            position: relative;
        }
        
        .media-type {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(0,0,0,0.7);
            color: white;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
        }
        
        .media-info {
            padding: 15px;
        }
        
        .media-name {
            font-weight: 600;
            margin-bottom: 5px;
            font-size: 14px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        
        .media-meta {
            display: flex;
            justify-content: space-between;
            color: var(--gray-500);
            font-size: 12px;
            margin-bottom: 10px;
        }
        
        .media-actions {
            display: flex;
            gap: 5px;
            justify-content: flex-end;
        }
        
        .upload-area {
            background: var(--gray-50);
            border: 3px dashed var(--primary-red);
            border-radius: 16px;
            padding: 40px;
            text-align: center;
            margin-bottom: 30px;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .upload-area:hover {
            background: var(--gray-100);
            border-color: var(--secondary-red);
        }
        
        .upload-area i {
            font-size: 50px;
            color: var(--primary-red);
            margin-bottom: 15px;
        }
        
        .upload-area h3 {
            font-size: 20px;
            margin-bottom: 10px;
            color: var(--gray-900);
        }
        
        .upload-area p {
            color: var(--gray-500);
        }
    </style>
</head>
<body>
    <div class="admin-sidebar">
        <div class="sidebar-header">
            <h2><span>ONNIEONE</span> NEWS</h2>
            <p>Admin Panel</p>
        </div>
        
        <div class="sidebar-menu">
            <div class="menu-section">Main</div>
            <a href="/admin/dashboard" class="menu-item">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </a>
            <a href="/admin/news" class="menu-item">
                <i class="fas fa-newspaper"></i>
                <span>All News</span>
            </a>
            <a href="/admin/news/add" class="menu-item">
                <i class="fas fa-plus-circle"></i>
                <span>Add News</span>
            </a>
            
            <div class="menu-divider"></div>
            <div class="menu-section">Content</div>
            <a href="/admin/categories" class="menu-item">
                <i class="fas fa-list"></i>
                <span>Categories</span>
            </a>
            <a href="/admin/regions" class="menu-item">
                <i class="fas fa-globe"></i>
                <span>Regions</span>
            </a>
            <a href="/admin/comments" class="menu-item">
                <i class="fas fa-comments"></i>
                <span>Comments</span>
            </a>
            <a href="/admin/media" class="menu-item active">
                <i class="fas fa-images"></i>
                <span>Media Library</span>
            </a>
            
            <div class="menu-divider"></div>
            <div class="menu-section">Tools</div>
            <a href="/admin/trending" class="menu-item">
                <i class="fas fa-fire"></i>
                <span>Find Trending</span>
            </a>
            <a href="/admin/settings" class="menu-item">
                <i class="fas fa-cog"></i>
                <span>Settings</span>
            </a>
            
            <div class="menu-divider"></div>
            <a href="/" target="_blank" class="menu-item">
                <i class="fas fa-external-link-alt"></i>
                <span>View Site</span>
            </a>
            <a href="/admin/logout" class="menu-item">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </a>
        </div>
    </div>

    <div class="admin-main">
        <div class="top-bar">
            <div class="page-title">
                <h1>Media Library</h1>
                <p>Manage images and files</p>
            </div>
            <div class="user-info">
                <span>Welcome, Admin</span>
                <div class="user-avatar">A</div>
            </div>
        </div>

        <div class="upload-area" onclick="document.getElementById('fileUpload').click()">
            <i class="fas fa-cloud-upload-alt"></i>
            <h3>Click to Upload Files</h3>
            <p>or drag and drop images here</p>
            <input type="file" id="fileUpload" multiple accept="image/*" style="display: none;">
        </div>

        <div class="table-container">
            <div class="table-header">
                <h2><i class="fas fa-images"></i> All Media</h2>
                <div style="display: flex; gap: 10px;">
                    <select class="select-control" style="width: 150px;">
                        <option>All Types</option>
                        <option>Images</option>
                        <option>Videos</option>
                        <option>Documents</option>
                    </select>
                </div>
            </div>

            <div class="media-grid">
                <div class="media-item">
                    <div class="media-preview" style="background-image: url('https://images.unsplash.com/photo-1461896836934-ffe607ba8211?w=500');">
                        <span class="media-type">JPG</span>
                    </div>
                    <div class="media-info">
                        <div class="media-name">sports-article-1.jpg</div>
                        <div class="media-meta">
                            <span>2.3 MB</span>
                            <span>1200x800</span>
                        </div>
                        <div class="media-actions">
                            <button class="btn-view"><i class="fas fa-eye"></i></button>
                            <button class="btn-edit"><i class="fas fa-edit"></i></button>
                            <button class="btn-delete"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                </div>

                <div class="media-item">
                    <div class="media-preview" style="background-image: url('https://images.unsplash.com/photo-1529107386315-e1a2ed48a620?w=500');">
                        <span class="media-type">JPG</span>
                    </div>
                    <div class="media-info">
                        <div class="media-name">politics-article-2.jpg</div>
                        <div class="media-meta">
                            <span>1.8 MB</span>
                            <span>1600x900</span>
                        </div>
                        <div class="media-actions">
                            <button class="btn-view"><i class="fas fa-eye"></i></button>
                            <button class="btn-edit"><i class="fas fa-edit"></i></button>
                            <button class="btn-delete"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                </div>

                <div class="media-item">
                    <div class="media-preview" style="background-image: url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=500');">
                        <span class="media-type">JPG</span>
                    </div>
                    <div class="media-info">
                        <div class="media-name">business-article-3.jpg</div>
                        <div class="media-meta">
                            <span>2.1 MB</span>
                            <span>1400x800</span>
                        </div>
                        <div class="media-actions">
                            <button class="btn-view"><i class="fas fa-eye"></i></button>
                            <button class="btn-edit"><i class="fas fa-edit"></i></button>
                            <button class="btn-delete"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                </div>

                <div class="media-item">
                    <div class="media-preview" style="background-image: url('https://images.unsplash.com/photo-1527224857830-43a7acc85260?w=500');">
                        <span class="media-type">JPG</span>
                    </div>
                    <div class="media-info">
                        <div class="media-name">comedy-article-4.jpg</div>
                        <div class="media-meta">
                            <span>1.5 MB</span>
                            <span>1000x1000</span>
                        </div>
                        <div class="media-actions">
                            <button class="btn-view"><i class="fas fa-eye"></i></button>
                            <button class="btn-edit"><i class="fas fa-edit"></i></button>
                            <button class="btn-delete"><i class="fas fa-trash"></i></button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="pagination" style="margin-top: 30px;">
                <a href="#" class="page-link active">1</a>
                <a href="#" class="page-link">2</a>
                <a href="#" class="page-link">3</a>
                <a href="#" class="page-link">4</a>
                <a href="#" class="page-link">5</a>
            </div>
        </div>
    </div>
</body>
</html>