<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Regions - ONNIEONE Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        .regions-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 25px;
            margin-top: 20px;
        }
        
        .region-card {
            background: var(--pure-white);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: var(--shadow-md);
            transition: all 0.3s;
            border-left: 5px solid var(--primary-red);
        }
        
        .region-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg);
        }
        
        .region-image {
            height: 150px;
            background-size: cover;
            background-position: center;
            position: relative;
        }
        
        .region-flag {
            position: absolute;
            top: 15px;
            right: 15px;
            font-size: 40px;
            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.3));
        }
        
        .region-content {
            padding: 20px;
        }
        
        .region-name {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 5px;
            color: var(--gray-900);
        }
        
        .region-slug {
            color: var(--gray-500);
            font-size: 13px;
            margin-bottom: 15px;
        }
        
        .region-stats {
            display: flex;
            justify-content: space-between;
            margin: 15px 0;
            padding: 10px 0;
            border-top: 1px solid var(--gray-200);
            border-bottom: 1px solid var(--gray-200);
        }
        
        .region-actions {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
        }
    </style>
</head>
<body>
    <div class="admin-sidebar">
        <div class="sidebar-header">
            <h2><span>ONNIEONE</span> NEWS</h2>
            <p>Admin Panel</p>
        </div>
        
        <div class="sidebar-menu">
            <div class="menu-section">Main</div>
            <a href="/admin/dashboard" class="menu-item">
                <i class="fas fa-tachometer-alt"></i>
                <span>Dashboard</span>
            </a>
            <a href="/admin/news" class="menu-item">
                <i class="fas fa-newspaper"></i>
                <span>All News</span>
            </a>
            <a href="/admin/news/add" class="menu-item">
                <i class="fas fa-plus-circle"></i>
                <span>Add News</span>
            </a>
            
            <div class="menu-divider"></div>
            <div class="menu-section">Content</div>
            <a href="/admin/categories" class="menu-item">
                <i class="fas fa-list"></i>
                <span>Categories</span>
            </a>
            <a href="/admin/regions" class="menu-item active">
                <i class="fas fa-globe"></i>
                <span>Regions</span>
            </a>
            <a href="/admin/comments" class="menu-item">
                <i class="fas fa-comments"></i>
                <span>Comments</span>
            </a>
            <a href="/admin/media" class="menu-item">
                <i class="fas fa-images"></i>
                <span>Media Library</span>
            </a>
            
            <div class="menu-divider"></div>
            <div class="menu-section">Tools</div>
            <a href="/admin/trending" class="menu-item">
                <i class="fas fa-fire"></i>
                <span>Find Trending</span>
            </a>
            <a href="/admin/settings" class="menu-item">
                <i class="fas fa-cog"></i>
                <span>Settings</span>
            </a>
            
            <div class="menu-divider"></div>
            <a href="/" target="_blank" class="menu-item">
                <i class="fas fa-external-link-alt"></i>
                <span>View Site</span>
            </a>
            <a href="/admin/logout" class="menu-item">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </a>
        </div>
    </div>

    <div class="admin-main">
        <div class="top-bar">
            <div class="page-title">
                <h1>Regions</h1>
                <p>Manage news regions</p>
            </div>
            <div class="user-info">
                <span>Welcome, Admin</span>
                <div class="user-avatar">A</div>
            </div>
        </div>

        <div class="table-container">
            <div class="table-header">
                <h2><i class="fas fa-globe"></i> All Regions</h2>
                <button class="btn-add" onclick="openAddModal()">
                    <i class="fas fa-plus-circle"></i> Add Region
                </button>
            </div>

            <div class="regions-grid">
                <div class="region-card">
                    <div class="region-image" style="background-image: url('https://images.unsplash.com/photo-1580066221083-664e16b986c7?w=500');">
                        <span class="region-flag">🇷🇼</span>
                    </div>
                    <div class="region-content">
                        <div class="region-name">Rwanda</div>
                        <div class="region-slug">/region/rwanda</div>
                        <div class="region-stats">
                            <span><i class="fas fa-newspaper"></i> 24 articles</span>
                            <span><i class="fas fa-eye"></i> 3.2k views</span>
                        </div>
                        <div class="region-actions">
                            <button class="btn-edit" onclick="editRegion(1)"><i class="fas fa-edit"></i> Edit</button>
                            <button class="btn-delete" onclick="deleteRegion(1)"><i class="fas fa-trash"></i> Delete</button>
                        </div>
                    </div>
                </div>

                <div class="region-card">
                    <div class="region-image" style="background-image: url('https://images.unsplash.com/photo-1547496502-89578615235f?w=500');">
                        <span class="region-flag">🇰🇪</span>
                    </div>
                    <div class="region-content">
                        <div class="region-name">Kenya</div>
                        <div class="region-slug">/region/kenya</div>
                        <div class="region-stats">
                            <span><i class="fas fa-newspaper"></i> 18 articles</span>
                            <span><i class="fas fa-eye"></i> 2.1k views</span>
                        </div>
                        <div class="region-actions">
                            <button class="btn-edit" onclick="editRegion(2)"><i class="fas fa-edit"></i> Edit</button>
                            <button class="btn-delete" onclick="deleteRegion(2)"><i class="fas fa-trash"></i> Delete</button>
                        </div>
                    </div>
                </div>

                <div class="region-card">
                    <div class="region-image" style="background-image: url('https://images.unsplash.com/photo-1523805009345-74488443a9e5?w=500');">
                        <span class="region-flag">🇳🇬</span>
                    </div>
                    <div class="region-content">
                        <div class="region-name">Nigeria</div>
                        <div class="region-slug">/region/nigeria</div>
                        <div class="region-stats">
                            <span><i class="fas fa-newspaper"></i> 32 articles</span>
                            <span><i class="fas fa-eye"></i> 4.5k views</span>
                        </div>
                        <div class="region-actions">
                            <button class="btn-edit" onclick="editRegion(3)"><i class="fas fa-edit"></i> Edit</button>
                            <button class="btn-delete" onclick="deleteRegion(3)"><i class="fas fa-trash"></i> Delete</button>
                        </div>
                    </div>
                </div>

                <div class="region-card">
                    <div class="region-image" style="background-image: url('https://images.unsplash.com/photo-1512470876302-972faa2aa9a4?w=500');">
                        <span class="region-flag">🇿🇦</span>
                    </div>
                    <div class="region-content">
                        <div class="region-name">South Africa</div>
                        <div class="region-slug">/region/south-africa</div>
                        <div class="region-stats">
                            <span><i class="fas fa-newspaper"></i> 27 articles</span>
                            <span><i class="fas fa-eye"></i> 3.8k views</span>
                        </div>
                        <div class="region-actions">
                            <button class="btn-edit" onclick="editRegion(4)"><i class="fas fa-edit"></i> Edit</button>
                            <button class="btn-delete" onclick="deleteRegion(4)"><i class="fas fa-trash"></i> Delete</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Add Region Modal -->
    <div class="modal" id="addModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Add New Region</h2>
                <button class="close-modal" onclick="closeAddModal()">&times;</button>
            </div>
            <form>
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <div class="form-group">
                    <label>Region Name *</label>
                    <input type="text" class="form-control" required placeholder="e.g., Tanzania">
                </div>
                <div class="form-group">
                    <label>Slug (URL)</label>
                    <input type="text" class="form-control" placeholder="e.g., tanzania">
                </div>
                <div class="form-group">
                    <label>Flag Emoji</label>
                    <input type="text" class="form-control" placeholder="e.g., 🇹🇿">
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea class="form-control" rows="3" placeholder="Region description"></textarea>
                </div>
                <div class="form-group">
                    <label>Region Image</label>
                    <input type="file" class="form-control" accept="image/*">
                </div>
                <button type="submit" class="btn-add" style="width: 100%;">Add Region</button>
            </form>
        </div>
    </div>

    <script>
        function openAddModal() {
            document.getElementById('addModal').classList.add('active');
        }

        function closeAddModal() {
            document.getElementById('addModal').classList.remove('active');
        }

        function editRegion(id) {
            alert('Edit region ' + id);
        }

        function deleteRegion(id) {
            if (confirm('Are you sure you want to delete this region?')) {
                alert('Region deleted successfully!');
            }
        }
    </script>
</body>
</html>