<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login - ONNIEONE NEWS</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #000;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .bg-pattern {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: #000;
            z-index: 0;
        }

        .bg-pattern::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: repeating-linear-gradient(45deg,
                    transparent,
                    transparent 20px,
                    rgba(220, 38, 38, 0.03) 20px,
                    rgba(220, 38, 38, 0.03) 40px);
            animation: moveBg 20s linear infinite;
        }

        @keyframes moveBg {
            0% {
                transform: translate(0, 0) rotate(0deg);
            }

            100% {
                transform: translate(50px, 50px) rotate(45deg);
            }
        }

        .login-container {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 450px;
            margin: 0 20px;
        }

        .login-card {
            background: #111;
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 50px 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            animation: slideUp 0.6s ease-out;
            border: 1px solid #333;
            position: relative;
            overflow: hidden;
        }

        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
            background: linear-gradient(90deg, #dc2626, #000, #dc2626);
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .logo {
            text-align: center;
            margin-bottom: 40px;
        }

        .logo h1 {
            font-size: 3rem;
            font-weight: 800;
            color: white;
            letter-spacing: -1px;
            text-shadow: 0 2px 10px rgba(220, 38, 38, 0.3);
        }

        .logo h1 span {
            color: #dc2626;
            position: relative;
            display: inline-block;
        }

        .logo h1 span::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 100%;
            height: 3px;
            background: #dc2626;
            border-radius: 2px;
            box-shadow: 0 0 10px #dc2626;
        }

        .logo p {
            color: #666;
            font-size: 1rem;
            margin-top: 15px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .form-group {
            margin-bottom: 25px;
            position: relative;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #999;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .input-icon {
            position: relative;
        }

        .input-icon i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #666;
            font-size: 1.1rem;
            transition: color 0.3s;
            z-index: 1;
        }

        .input-icon input {
            width: 100%;
            padding: 15px 15px 15px 45px;
            background: #1a1a1a;
            border: 2px solid #333;
            border-radius: 12px;
            font-size: 1rem;
            transition: all 0.3s;
            color: white;
        }

        .input-icon input:focus {
            outline: none;
            border-color: #dc2626;
            box-shadow: 0 0 0 4px rgba(220, 38, 38, 0.2);
            background: #222;
        }

        .input-icon input:focus+i {
            color: #dc2626;
        }

        .login-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #dc2626 0%, #b91c1c 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
            overflow: hidden;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .login-btn:hover {
            background: linear-gradient(135deg, #b91c1c 0%, #991b1b 100%);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(220, 38, 38, 0.4);
        }

        .error-message {
            background: rgba(220, 38, 38, 0.1);
            border: 1px solid #dc2626;
            color: #dc2626;
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 25px;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .demo-creds {
            background: #1a1a1a;
            border-radius: 12px;
            padding: 20px;
            margin-top: 30px;
            text-align: center;
            border: 1px solid #333;
        }

        .demo-creds p {
            color: #999;
            font-size: 0.9rem;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .demo-creds .creds {
            display: flex;
            justify-content: center;
            gap: 30px;
            color: #ccc;
            font-size: 1rem;
            background: #222;
            padding: 10px;
            border-radius: 8px;
        }

        .demo-creds .creds span {
            font-weight: 700;
            color: #dc2626;
        }

        .footer {
            text-align: center;
            margin-top: 25px;
            color: #666;
            font-size: 0.9rem;
        }
    </style>
</head>

<body>
    <div class="bg-pattern"></div>

    <div class="login-container">
        <div class="login-card">
            <div class="logo">
                <h1>ONNIEONE <span>NEWS</span></h1>
                <p>Admin Portal</p>
            </div>

            <% if (locals.error) { %>
                <div class="error-message">
                    <i class="fas fa-exclamation-circle"></i>
                    Invalid username or password
                </div>
                <% } %>

                    <form action="/admin/login" method="POST" id="loginForm">
                        <input type="hidden" name="_csrf"
                            value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                        <div class="form-group">
                            <label>Username</label>
                            <div class="input-icon">
                                <i class="fas fa-user"></i>
                                <input type="text" name="username" placeholder="Enter your username" required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>Password</label>
                            <div class="input-icon">
                                <i class="fas fa-lock"></i>
                                <input type="password" name="password" placeholder="Enter your password" required>
                            </div>
                        </div>

                        <button type="submit" class="login-btn">
                            <i class="fas fa-sign-in-alt"></i>
                            Login to Dashboard
                        </button>
                    </form>



                    <div class="footer">
                        <p>© 2026 ONNIEONE NEWS. All rights reserved.</p>
                    </div>
        </div>
    </div>
</body>

</html>