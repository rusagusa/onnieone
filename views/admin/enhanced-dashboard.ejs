<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - ONNIEONE NEWS</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/admin-enhanced.css">
</head>
<body>
    <div class="admin-wrapper">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="sidebar-header">
                <h2><span>ONNIEONE</span> NEWS</h2>
                <p>Admin Panel</p>
            </div>
            
            <div class="sidebar-menu">
                <div class="menu-category">MAIN</div>
                <a href="/admin/dashboard" class="menu-item active">
                    <i class="fas fa-tachometer-alt"></i> Dashboard
                </a>
                <a href="/admin/news" class="menu-item">
                    <i class="fas fa-newspaper"></i> All News
                </a>
                <a href="/admin/news/add" class="menu-item">
                    <i class="fas fa-plus-circle"></i> Add News
                </a>
                
                <div class="menu-category">CONTENT</div>
                <a href="/admin/categories" class="menu-item">
                    <i class="fas fa-list"></i> Categories
                </a>
                <a href="/admin/featured" class="menu-item">
                    <i class="fas fa-star"></i> Featured Articles
                </a>
                <a href="/admin/breaking" class="menu-item">
                    <i class="fas fa-bolt"></i> Breaking News
                </a>
                <a href="/admin/popular" class="menu-item">
                    <i class="fas fa-fire"></i> Popular News
                </a>
                
                <div class="menu-category">MEDIA</div>
                <a href="/admin/media" class="menu-item">
                    <i class="fas fa-images"></i> Media Library
                </a>
                <a href="/admin/videos" class="menu-item">
                    <i class="fas fa-video"></i> Videos
                </a>
                <a href="/admin/galleries" class="menu-item">
                    <i class="fas fa-photo-video"></i> Photo Galleries
                </a>
                
                <div class="menu-category">SECTIONS</div>
                <a href="/admin/auctions" class="menu-item">
                    <i class="fas fa-gavel"></i> Auctions
                </a>
                <a href="/admin/announcements" class="menu-item">
                    <i class="fas fa-bullhorn"></i> Announcements
                </a>
                <a href="/admin/history" class="menu-item">
                    <i class="fas fa-history"></i> Today in History
                </a>
                
                <div class="menu-category">USERS</div>
                <a href="/admin/users" class="menu-item">
                    <i class="fas fa-users"></i> Manage Users
                </a>
                <a href="/admin/comments" class="menu-item">
                    <i class="fas fa-comments"></i> Comments
                </a>
                
                <div class="menu-category">SETTINGS</div>
                <a href="/admin/settings" class="menu-item">
                    <i class="fas fa-cog"></i> Site Settings
                </a>
                <a href="/admin/profile" class="menu-item">
                    <i class="fas fa-user"></i> Profile
                </a>
                <a href="/admin/logout" class="menu-item">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </div>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Top Bar -->
            <div class="top-bar">
                <div class="page-title">
                    <h1>Dashboard</h1>
                    <p>Welcome back, <%= user.full_name || 'Admin' %></p>
                </div>
                <div class="user-info">
                    <div class="user-avatar">
                        <%= user.full_name ? user.full_name.charAt(0).toUpperCase() : user.username.charAt(0).toUpperCase() %>
                    </div>
                    <a href="/admin/logout" class="btn-logout">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-info">
                        <h3>Total Articles</h3>
                        <div class="number"><%= stats.totalArticles || 0 %></div>
                    </div>
                    <div class="stat-icon">
                        <i class="fas fa-newspaper"></i>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-info">
                        <h3>Total Views</h3>
                        <div class="number"><%= stats.totalViews ? stats.totalViews.toLocaleString() : 0 %></div>
                    </div>
                    <div class="stat-icon">
                        <i class="fas fa-eye"></i>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-info">
                        <h3>Categories</h3>
                        <div class="number"><%= stats.totalCategories || 0 %></div>
                    </div>
                    <div class="stat-icon">
                        <i class="fas fa-list"></i>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-info">
                        <h3>Comments</h3>
                        <div class="number"><%= stats.totalComments || 0 %></div>
                    </div>
                    <div class="stat-icon">
                        <i class="fas fa-comments"></i>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="content-card">
                <div class="card-header">
                    <h2><i class="fas fa-bolt"></i> Quick Actions</h2>
                </div>
                <div class="quick-actions">
                    <a href="/admin/news/add" class="quick-action-item">
                        <i class="fas fa-plus-circle"></i>
                        <span>Add News</span>
                    </a>
                    <a href="/admin/categories" class="quick-action-item">
                        <i class="fas fa-tag"></i>
                        <span>Add Category</span>
                    </a>
                    <a href="/admin/media/upload" class="quick-action-item">
                        <i class="fas fa-upload"></i>
                        <span>Upload Media</span>
                    </a>
                    <a href="/admin/featured" class="quick-action-item">
                        <i class="fas fa-star"></i>
                        <span>Featured</span>
                    </a>
                    <a href="/admin/breaking" class="quick-action-item">
                        <i class="fas fa-bolt"></i>
                        <span>Breaking News</span>
                    </a>
                    <a href="/admin/auctions" class="quick-action-item">
                        <i class="fas fa-gavel"></i>
                        <span>Auctions</span>
                    </a>
                </div>
            </div>

            <!-- Recent Articles -->
            <div class="content-card">
                <div class="card-header">
                    <h2><i class="fas fa-history"></i> Recent Articles</h2>
                    <a href="/admin/news" class="btn btn-outline btn-sm">View All</a>
                </div>
                
                <div class="table-responsive">
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Title</th>
                                <th>Category</th>
                                <th>Views</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (recentArticles && recentArticles.length > 0) { %>
                                <% recentArticles.forEach(article => { %>
                                    <tr>
                                        <td>#<%= article.id %></td>
                                        <td>
                                            <strong><%= article.title_en %></strong>
                                            <% if (article.is_featured) { %>
                                                <span class="status-badge status-featured" style="margin-left: 5px;">Featured</span>
                                            <% } %>
                                            <% if (article.is_breaking) { %>
                                                <span class="status-badge status-breaking" style="margin-left: 5px;">Breaking</span>
                                            <% } %>
                                        </td>
                                        <td><%= article.category_name || 'Uncategorized' %></td>
                                        <td><%= article.views ? article.views.toLocaleString() : 0 %></td>
                                        <td>
                                            <span class="status-badge status-<%= article.status || 'published' %>">
                                                <%= article.status || 'published' %>
                                            </span>
                                        </td>
                                        <td>
                                            <div><%= new Date(article.published_at).toLocaleDateString() %></div>
                                            <small style="color: #999;"><%= new Date(article.published_at).toLocaleTimeString() %></small>
                                        </td>
                                        <td class="action-buttons">
                                            <a href="/admin/news/edit/<%= article.id %>" class="btn btn-success btn-sm">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a href="/article/<%= article.id %>" target="_blank" class="btn btn-primary btn-sm">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <button onclick="deleteArticle(<%= article.id %>)" class="btn btn-danger btn-sm">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" style="text-align: center; padding: 30px;">
                                        <i class="fas fa-newspaper" style="font-size: 3rem; color: #ddd; margin-bottom: 15px;"></i>
                                        <p>No articles yet.</p>
                                        <a href="/admin/news/add" class="btn btn-primary btn-sm">Add your first article</a>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Activity Overview -->
            <div class="content-card">
                <div class="card-header">
                    <h2><i class="fas fa-chart-line"></i> Activity Overview</h2>
                </div>
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
                    <div style="text-align: center;">
                        <div style="font-size: 2rem; font-weight: bold; color: #dc2626;"><%= stats.thisWeek || 12 %></div>
                        <div style="color: #666;">Articles This Week</div>
                    </div>
                    <div style="text-align: center;">
                        <div style="font-size: 2rem; font-weight: bold; color: #dc2626;"><%= stats.todayViews || 345 %></div>
                        <div style="color: #666;">Views Today</div>
                    </div>
                    <div style="text-align: center;">
                        <div style="font-size: 2rem; font-weight: bold; color: #dc2626;"><%= stats.pendingComments || 3 %></div>
                        <div style="color: #666;">Pending Comments</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function deleteArticle(id) {
            if (confirm('Are you sure you want to delete this article? This action cannot be undone.')) {
                fetch('/admin/news/delete/' + id, { method: 'POST', headers: { 'CSRF-Token': '<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>' } })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            location.reload();
                        } else {
                            alert('Error deleting article');
                        }
                    });
            }
        }
    </script>
</body>
</html>
