<%- layout('admin/layout', { pageTitle: 'Comments Management' , currentPage: 'comments' , user: user }) %>

    <div class="content-card">
        <div class="card-header">
            <h2><i class="fas fa-comments"></i> Manage Comments</h2>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Article</th>
                        <th>Name</th>
                        <th>Comment</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (comments && comments.length> 0) { %>
                        <% comments.forEach(c=> { %>
                            <tr>
                                <td>#<%= c.id %>
                                </td>
                                <td><strong>
                                        <%= c.article_title %>
                                    </strong></td>
                                <td>
                                    <%= c.name %><br><small>
                                            <%= c.email %>
                                        </small>
                                </td>
                                <td>
                                    <%= c.comment.length> 50 ? c.comment.substring(0, 50) + '...' : c.comment %>
                                </td>
                                <td>
                                    <span
                                        class="status-badge <%= c.is_approved ? 'status-active' : 'status-inactive' %>">
                                        <%= c.is_approved ? 'Approved' : 'Pending' %>
                                    </span>
                                </td>
                                <td>
                                    <%= new Date(c.created_at).toLocaleDateString() %>
                                </td>
                                <td class="action-buttons">
                                    <button onclick="toggleComment(<%= c.id %>, <%= c.is_approved %>)"
                                        class="btn-warning"
                                        style="background: <%= c.is_approved ? '#f59e0b' : '#10b981' %>; color: white; padding:5px 10px; border:none; border-radius:5px; margin-right: 5px;">
                                        <i class="fas <%= c.is_approved ? 'fa-ban' : 'fa-check' %>"></i>
                                    </button>
                                    <button onclick="deleteComment(<%= c.id %>)" class="btn-delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" style="text-align: center; padding: 30px;">
                                            No comments found.
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        function toggleComment(id, current) {
            if (confirm(`Are you sure you want to ${current ? 'hide' : 'approve'} this comment?`)) {
                fetch('/admin/comments/toggle/' + id, { method: 'POST', headers: { 'CSRF-Token': '<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>' } })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            location.reload();
                        }
                    });
            }
        }

        function deleteComment(id) {
            if (confirm('Are you sure you want to delete this comment?')) {
                fetch('/admin/comments/delete/' + id, { method: 'POST', headers: { 'CSRF-Token': '<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>' } })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            location.reload();
                        }
                    });
            }
        }
    </script>