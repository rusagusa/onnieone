<%- layout('admin/layout', { pageTitle: 'Auctions Management' , currentPage: 'auctions' , user: user }) %>

    <div class="content-card">
        <div class="card-header">
            <h2><i class="fas fa-gavel"></i> Manage Auctions</h2>
            <button class="btn btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
                <i class="fas fa-plus"></i> Add Auction
            </button>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Price</th>
                        <th>Location</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (auctions && auctions.length> 0) { %>
                        <% auctions.forEach(a=> { %>
                            <tr>
                                <td>#<%= a.id %>
                                </td>
                                <td><strong>
                                        <%= a.title_en %>
                                    </strong></td>
                                <td>
                                    <%= a.price %>
                                </td>
                                <td>
                                    <%= a.location %>
                                </td>
                                <td>
                                    <%= new Date(a.end_date).toLocaleDateString() %>
                                </td>
                                <td>
                                    <span class="status-badge <%= a.is_active ? 'status-active' : 'status-inactive' %>">
                                        <%= a.is_active ? 'Active' : 'Closed' %>
                                    </span>
                                </td>
                                <td class="action-buttons">
                                    <button onclick="toggleAuction(<%= a.id %>)" class="btn-warning"
                                        style="background: #f59e0b; color: white; border: none; padding: 5px 10px; border-radius: 5px; margin-right: 5px;">
                                        <i class="fas fa-toggle-<%= a.is_active ? 'on' : 'off' %>"></i>
                                    </button>
                                    <button onclick="deleteAuction(<%= a.id %>)" class="btn-delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" style="text-align: center; padding: 30px;">
                                            No auctions found.
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Add Modal -->
    <div id="addModal"
        style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); justify-content:center; align-items:center; z-index:1000;">
        <div style="background:white; padding:30px; border-radius:10px; width:400px;">
            <h3 style="margin-top:0;">Add Auction</h3>
            <form action="/admin/auctions/add" method="POST">
                <input type="text" name="title_en" placeholder="Auction Title" required
                    style="width:100%; padding:10px; margin-bottom:15px; border:1px solid #ccc; border-radius:5px;">
                <input type="text" name="price" placeholder="Starting Price (e.g. 1000 RWF)" required
                    style="width:100%; padding:10px; margin-bottom:15px; border:1px solid #ccc; border-radius:5px;">
                <input type="text" name="location" placeholder="Location" required
                    style="width:100%; padding:10px; margin-bottom:15px; border:1px solid #ccc; border-radius:5px;">
                <label style="display:block; margin-bottom:5px;">End Date:</label>
                <input type="datetime-local" name="end_date" required
                    style="width:100%; padding:10px; margin-bottom:20px; border:1px solid #ccc; border-radius:5px;">
                <div style="display:flex; justify-content:space-between;">
                    <button type="button" onclick="document.getElementById('addModal').style.display='none'"
                        style="padding:10px 20px; background:#e5e7eb; border:none; border-radius:5px; cursor:pointer;">Cancel</button>
                    <button type="submit"
                        style="padding:10px 20px; background:#dc2626; color:white; border:none; border-radius:5px; cursor:pointer;">Save
                        Auction</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function toggleAuction(id) {
            fetch('/admin/auctions/toggle/' + id, { method: 'POST', headers: { 'CSRF-Token': '<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>' } })
                .then(res => res.json())
                .then(data => {
                    if (data.success) location.reload();
                });
        }

        function deleteAuction(id) {
            if (confirm('Are you sure you want to delete this auction?')) {
                fetch('/admin/auctions/delete/' + id, { method: 'POST', headers: { 'CSRF-Token': '<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>' } })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) location.reload();
                    });
            }
        }
    </script>