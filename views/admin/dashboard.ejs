<%- layout('admin/layout', { pageTitle: 'Dashboard' , currentPage: 'dashboard' , user: user }) %>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-info">
                <h3>Total Articles</h3>
                <div class="number">
                    <%= stats.totalArticles || 0 %>
                </div>
            </div>
            <div class="stat-icon"><i class="fas fa-newspaper"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>Total Views</h3>
                <div class="number">
                    <%= (stats.totalViews || 0).toLocaleString() %>
                </div>
            </div>
            <div class="stat-icon"><i class="fas fa-eye"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>Categories</h3>
                <div class="number">
                    <%= stats.totalCategories || 0 %>
                </div>
            </div>
            <div class="stat-icon"><i class="fas fa-list"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>Active Ads</h3>
                <div class="number">
                    <%= stats.totalAds || 0 %>
                </div>
            </div>
            <div class="stat-icon"><i class="fas fa-ad"></i></div>
        </div>
    </div>

    <div class="content-card">
        <div class="card-header">
            <h2><i class="fas fa-clock"></i> Recent Articles</h2>
            <a href="/admin/news/add" class="btn btn-primary">
                <i class="fas fa-plus"></i> Add News
            </a>
        </div>
        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (recentArticles && recentArticles.length> 0) { %>
                        <% recentArticles.forEach(article=> { %>
                            <tr>
                                <td><strong>
                                        <%= article.title_en %>
                                    </strong></td>
                                <td>
                                    <%= article.category_name || 'Uncategorized' %>
                                </td>
                                <td>
                                    <span class="status-badge status-<%= article.status %>">
                                        <%= article.status.charAt(0).toUpperCase() + article.status.slice(1) %>
                                    </span>
                                </td>
                                <td>
                                    <%= new Date(article.created_at).toLocaleDateString() %>
                                </td>
                                <td class="action-buttons">
                                    <a href="/admin/news/edit/<%= article.id %>" class="btn-edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" style="text-align: center; padding: 40px; color: #6b7280;">
                                            <i class="fas fa-newspaper"
                                                style="font-size: 2rem; display: block; margin-bottom: 10px;"></i>
                                            No articles yet. <a href="/admin/news/add" style="color: #dc2626;">Add your
                                                first article!</a>
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <div class="content-card"
        style="background: linear-gradient(135deg, #000 0%, #1a1a1a 100%); color: white; border: none;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <h2 style="color: white; font-size: 1.3rem; margin-bottom: 10px;">
                    <i class="fas fa-edit" style="color: #dc2626;"></i> Live Editor
                </h2>
                <p style="color: #9ca3af;">Edit the homepage content directly — change headlines, swap images and ads in
                    real time.</p>
            </div>
            <a href="/admin/live-editor" class="btn btn-primary" style="white-space: nowrap;">
                <i class="fas fa-edit"></i> Open Live Editor
            </a>
        </div>
    </div>