<%- layout('admin/layout', { pageTitle: 'Manage News' , currentPage: 'news' , user: user }) %>

    <% const sq=locals.searchQuery || '' ; const tp=locals.totalPages || 0; const cp=locals.currentPage || 1; %>

        <div class="content-card">
            <div class="card-header">
                <h2><i class="fas fa-newspaper"></i> All Articles</h2>
                <a href="/admin/news/add" class="btn btn-primary">
                    <i class="fas fa-plus-circle"></i> Add New
                </a>
            </div>

            <!-- Search -->
            <div style="margin-bottom: 20px;">
                <form action="/admin/news" method="GET" style="display: flex; gap: 10px;">
                    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="text" name="search" class="form-control" placeholder="Search articles..."
                        value="<%= sq %>" style="flex: 1;">
                    <button type="submit" class="btn btn-primary">Search</button>
                </form>
            </div>

            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Views</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (locals.news && news.length> 0) { %>
                        <% news.forEach(article=> { %>
                            <tr>
                                <td>
                                    <%= article.id %>
                                </td>
                                <td>
                                    <%= article.title_en %>
                                </td>
                                <td>
                                    <%= article.category_name || 'Uncategorized' %>
                                </td>
                                <td>
                                    <%= article.views || 0 %>
                                </td>
                                <td>
                                    <span class="status-badge status-<%= article.status || 'published' %>">
                                        <%= article.status || 'published' %>
                                    </span>
                                </td>
                                <td>
                                    <%= new Date(article.published_at).toLocaleDateString() %>
                                </td>
                                <td class="action-buttons">
                                    <a href="/admin/news/edit/<%= article.id %>" class="btn btn-success btn-sm">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="/article/<%= article.id %>" target="_blank" class="btn btn-primary btn-sm">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <button onclick="deleteArticle(<%= article.id %>)" class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" style="text-align: center; padding: 30px;">
                                            No articles found. <a href="/admin/news/add">Add your first article</a>
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>

            <!-- Pagination -->
            <% if (tp> 1) { %>
                <div style="margin-top: 20px; display: flex; justify-content: center; gap: 10px;">
                    <% for (let i=1; i <=tp; i++) { %>
                        <a href="?page=<%= i %><%= sq ? '&search=' + sq : '' %>"
                            class="btn <%= i === cp ? 'btn-primary' : 'btn' %>">
                            <%= i %>
                        </a>
                        <% } %>
                </div>
                <% } %>
        </div>

        <script>
            function deleteArticle(id) {
                if (confirm('Are you sure you want to delete this article?')) {
                    fetch('/admin/news/delete/' + id, { method: 'POST', headers: { 'CSRF-Token': '<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>' } })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                location.reload();
                            } else {
                                alert('Error deleting article');
                            }
                        });
                }
            }
        </script>