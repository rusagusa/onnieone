<%- layout('admin/layout', { 
    pageTitle: 'User Management', 
    currentPage: 'users',
    user: user 
}) %>

<div class="content-card">
    <div class="card-header">
        <h2><i class="fas fa-users"></i> All Users</h2>
        <a href="/admin/users/add" class="btn btn-primary">
            <i class="fas fa-user-plus"></i> Add User
        </a>
    </div>
    
    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% if (users && users.length > 0) { %>
                    <% users.forEach(u => { %>
                        <tr>
                            <td>#<%= u.id %></td>
                            <td><strong><%= u.username %></strong></td>
                            <td><%= u.full_name || '-' %></td>
                            <td><%= u.email || '-' %></td>
                            <td>
                                <span class="status-badge" style="background: <%= u.role === 'admin' ? '#dc2626' : '#3b82f6' %>; color: white;">
                                    <%= u.role %>
                                </span>
                            </td>
                            <td>
                                <span class="status-badge <%= u.is_active ? 'status-active' : 'status-inactive' %>">
                                    <%= u.is_active ? 'Active' : 'Inactive' %>
                                </span>
                            </td>
                            <td><%= new Date(u.created_at).toLocaleDateString() %></td>
                            <td class="action-buttons">
                                <a href="/admin/users/edit/<%= u.id %>" class="btn-edit">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button onclick="toggleUser(<%= u.id %>, <%= u.is_active %>)" class="btn-warning" style="background: #f59e0b; color: white; padding:5px 10px; border:none; border-radius:5px;">
                                    <i class="fas fa-toggle-<%= u.is_active ? 'on' : 'off' %>"></i>
                                </button>
                                <% if (u.username !== 'admin') { %>
                                    <button onclick="deleteUser(<%= u.id %>)" class="btn-delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="8" style="text-align: center; padding: 30px;">
                            No users found.
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
function toggleUser(id, current) {
    fetch('/admin/users/toggle/' + id, { method: 'POST', headers: { 'CSRF-Token': '<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>' } })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                location.reload();
            }
        });
}

function deleteUser(id) {
    if (confirm('Are you sure you want to delete this user?')) {
        fetch('/admin/users/delete/' + id, { method: 'POST', headers: { 'CSRF-Token': '<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>' } })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error deleting user');
                }
            });
    }
}
</script>
