<%- layout('admin/layout', { pageTitle: 'Gallery Management' , currentPage: 'galleries' , user: user }) %>

    <div class="content-card">
        <div class="card-header">
            <h2><i class="fas fa-images"></i> Manage Galleries</h2>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Preview</th>
                        <th>Filename</th>
                        <th>Type</th>
                        <th>Uploader</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (media && media.length> 0) { %>
                        <% media.forEach(m=> { %>
                            <tr>
                                <td>#<%= m.id %>
                                </td>
                                <td>
                                    <img src="<%= m.path %>"
                                        style="width: 80px; height: 80px; object-fit: cover; border-radius: 5px;">
                                </td>
                                <td>
                                    <%= m.original_name %>
                                </td>
                                <td>
                                    <%= m.type %>
                                </td>
                                <td>
                                    <%= m.uploader_name || 'Admin' %>
                                </td>
                                <td>
                                    <%= new Date(m.created_at).toLocaleDateString() %>
                                </td>
                                <td class="action-buttons">
                                    <button onclick="deleteMedia(<%= m.id %>)" class="btn-delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" style="text-align: center; padding: 30px;">
                                            No gallery images found. Check individual articles.
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        function deleteMedia(id) {
            if (confirm('Are you sure you want to delete this image?')) {
                fetch('/admin/media/delete/' + id, { method: 'POST', headers: { 'CSRF-Token': '<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>' } })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            location.reload();
                        }
                    });
            }
        }
    </script>