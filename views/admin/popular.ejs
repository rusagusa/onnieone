<%- layout('admin/layout', { pageTitle: 'Popular Articles' , currentPage: 'popular' , user: user }) %>

    <div class="content-card">
        <div class="card-header">
            <h2><i class="fas fa-fire"></i> Most Popular Articles (Top 50)</h2>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Title</th>
                        <th>Views</th>
                        <th>Category</th>
                        <th>Published</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (articles && articles.length> 0) { %>
                        <% articles.forEach((a, index)=> { %>
                            <tr>
                                <td>#<%= index + 1 %>
                                </td>
                                <td><strong>
                                        <%= a.title_en %>
                                    </strong></td>
                                <td><span style="color:#dc2626; font-weight:bold;">
                                        <%= a.views %>
                                    </span> <i class="fas fa-eye" style="color:#9ca3af; font-size:12px;"></i></td>
                                <td>
                                    <%= a.category_name || 'Uncategorized' %>
                                </td>
                                <td>
                                    <%= new Date(a.published_at || a.created_at).toLocaleDateString() %>
                                </td>
                                <td class="action-buttons">
                                    <a href="/admin/news/edit/<%= a.id %>" class="btn-edit" title="Edit Article">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="/article/<%= a.id %>" target="_blank" class="btn-primary"
                                        style="padding: 5px 10px; border-radius: 5px; font-size: 14px;"
                                        title="View on Site">
                                        <i class="fas fa-external-link-alt"></i>
                                    </a>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" style="text-align: center; padding: 30px;">
                                            No articles found or no views recorded yet.
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>