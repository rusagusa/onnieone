<%- layout('admin/layout', { pageTitle: 'Today in History Management' , currentPage: 'history' , user: user }) %>

    <div class="content-card">
        <div class="card-header">
            <h2><i class="fas fa-history"></i> Manage 'Today in History'</h2>
            <button class="btn btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
                <i class="fas fa-plus"></i> Add Event
            </button>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Year</th>
                        <th>Event Description</th>
                        <th>Status</th>
                        <th>Date Added</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (history && history.length> 0) { %>
                        <% history.forEach(h=> { %>
                            <tr>
                                <td>#<%= h.id %>
                                </td>
                                <td><strong>
                                        <%= h.year %>
                                    </strong></td>
                                <td>
                                    <%= h.event_en %>
                                </td>
                                <td>
                                    <span class="status-badge <%= h.is_active ? 'status-active' : 'status-inactive' %>">
                                        <%= h.is_active ? 'Active' : 'Hidden' %>
                                    </span>
                                </td>
                                <td>
                                    <%= new Date(h.created_at).toLocaleDateString() %>
                                </td>
                                <td class="action-buttons">
                                    <button onclick="toggleHistory(<%= h.id %>)" class="btn-warning"
                                        style="background: #f59e0b; color: white; border: none; padding: 5px 10px; border-radius: 5px; margin-right: 5px;">
                                        <i class="fas fa-toggle-<%= h.is_active ? 'on' : 'off' %>"></i>
                                    </button>
                                    <button onclick="deleteHistory(<%= h.id %>)" class="btn-delete">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" style="text-align: center; padding: 30px;">
                                            No history events found.
                                        </td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Add Modal -->
    <div id="addModal"
        style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); justify-content:center; align-items:center; z-index:1000;">
        <div style="background:white; padding:30px; border-radius:10px; width:400px;">
            <h3 style="margin-top:0;">Add Historical Event</h3>
            <form action="/admin/history/add" method="POST">
                <input type="number" name="year" placeholder="Year (e.g. 1994)" required
                    style="width:100%; padding:10px; margin-bottom:15px; border:1px solid #ccc; border-radius:5px;">
                <textarea name="event_en" placeholder="Event Description" required rows="4"
                    style="width:100%; padding:10px; margin-bottom:20px; border:1px solid #ccc; border-radius:5px; font-family:inherit;"></textarea>
                <div style="display:flex; justify-content:space-between;">
                    <button type="button" onclick="document.getElementById('addModal').style.display='none'"
                        style="padding:10px 20px; background:#e5e7eb; border:none; border-radius:5px; cursor:pointer;">Cancel</button>
                    <button type="submit"
                        style="padding:10px 20px; background:#dc2626; color:white; border:none; border-radius:5px; cursor:pointer;">Save
                        Event</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function toggleHistory(id) {
            fetch('/admin/history/toggle/' + id, { method: 'POST', headers: { 'CSRF-Token': '<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>' } })
                .then(res => res.json())
                .then(data => {
                    if (data.success) location.reload();
                });
        }

        function deleteHistory(id) {
            if (confirm('Are you sure you want to delete this event?')) {
                fetch('/admin/history/delete/' + id, { method: 'POST', headers: { 'CSRF-Token': '<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>' } })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) location.reload();
                    });
            }
        }
    </script>