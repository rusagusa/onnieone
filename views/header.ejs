<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ONNIEONE News - Africa's Trusted News Source</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="site-header">
        <div class="container">
            <div class="header-top">
                <div class="logo">
                    <a href="/">
                        <span class="logo-onnieone">ONNIEONE</span>
                        <span class="logo-news">NEWS</span>
                    </a>
                </div>
                <div class="header-right">
                    <div class="search-box">
                        <form action="/search" method="GET">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                            <input type="text" name="q" placeholder="Search news...">
                            <button type="submit"><i class="fas fa-search"></i></button>
                        </form>
                    </div>
                    <div class="social-links">
                        <a href="#" target="_blank"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" target="_blank"><i class="fab fa-twitter"></i></a>
                        <a href="#" target="_blank"><i class="fab fa-instagram"></i></a>
                        <a href="#" target="_blank"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
            </div>
            <nav class="main-nav">
                <ul class="nav-menu">
                    <li><a href="/">Home</a></li>
                    <li><a href="/trending"><i class="fas fa-fire"></i> Trending</a></li>
                    <li class="dropdown">
                        <a href="/categories">Categories <i class="fas fa-chevron-down"></i></a>
                        <ul class="dropdown-menu">
                            <li><a href="/category/sports"><i class="fas fa-futbol"></i> Sports</a></li>
                            <li><a href="/category/entertainment"><i class="fas fa-film"></i> Entertainment</a></li>
                            <li><a href="/category/politics"><i class="fas fa-landmark"></i> Politics</a></li>
                            <li><a href="/category/business"><i class="fas fa-chart-line"></i> Business</a></li>
                            <li><a href="/category/comedy"><i class="fas fa-laugh"></i> Comedy</a></li>
                        </ul>
                    </li>
                    <li class="dropdown">
                        <a href="/regions">Regions <i class="fas fa-chevron-down"></i></a>
                        <ul class="dropdown-menu">
                            <li><a href="/region/rwanda"><span class="region-flag">🇷🇼</span> Rwanda</a></li>
                            <li><a href="/region/east-africa"><span class="region-flag">🌍</span> East Africa</a></li>
                            <li><a href="/region/west-africa"><span class="region-flag">🌍</span> West Africa</a></li>
                            <li><a href="/region/south-africa"><span class="region-flag">🇿🇦</span> South Africa</a></li>
                            <li><a href="/region/central-africa"><span class="region-flag">🌍</span> Central Africa</a></li>
                        </ul>
                    </li>
                </ul>
                <div class="nav-buttons">
                    <a href="/admin/login" class="btn-admin"><i class="fas fa-lock"></i> Admin</a>
                </div>
            </nav>
        </div>
    </header>
