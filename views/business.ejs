                    <li style="margin-bottom: 12px;"><a href="/regions" style="color: #9ca3af; text-decoration: none; transition: color 0.3s; display: flex; align-items: center; gap: 8px;"><i class="fas fa-globe" style="color: #dc2626; font-size: 12px;"></i> Regions</a></li>
                    <li style="margin-bottom: 12px;"><a href="/about" style="color: #9ca3af; text-decoration: none; transition: color 0.3s; display: flex; align-items: center; gap: 8px;"><i class="fas fa-info-circle" style="color: #dc2626; font-size: 12px;"></i> About Us</a></li>
                    <li style="margin-bottom: 12px;"><a href="/contact" style="color: #9ca3af; text-decoration: none; transition: color 0.3s; display: flex; align-items: center; gap: 8px;"><i class="fas fa-envelope" style="color: #dc2626; font-size: 12px;"></i> Contact</a></li>
                </ul>
            </div>

            <!-- Markets -->
            <div>
                <h3 style="color: #dc2626; font-size: 20px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-chart-pie"></i> Markets
                </h3>
                <ul style="list-style: none;">
                    <li style="margin-bottom: 12px;"><a href="#" style="color: #9ca3af; text-decoration: none; transition: color 0.3s; display: flex; align-items: center; gap: 8px;"><i class="fas fa-dollar-sign" style="color: #dc2626; font-size: 12px;"></i> Stocks</a></li>
                    <li style="margin-bottom: 12px;"><a href="#" style="color: #9ca3af; text-decoration: none; transition: color 0.3s; display: flex; align-items: center; gap: 8px;"><i class="fas fa-coins" style="color: #dc2626; font-size: 12px;"></i> Currencies</a></li>
                    <li style="margin-bottom: 12px;"><a href="#" style="color: #9ca3af; text-decoration: none; transition: color 0.3s; display: flex; align-items: center; gap: 8px;"><i class="fas fa-chart-bar" style="color: #dc2626; font-size: 12px;"></i> Commodities</a></li>
                    <li style="margin-bottom: 12px;"><a href="#" style="color: #9ca3af; text-decoration: none; transition: color 0.3s; display: flex; align-items: center; gap: 8px;"><i class="fas fa-bitcoin" style="color: #dc2626; font-size: 12px;"></i> Crypto</a></li>
                    <li style="margin-bottom: 12px;"><a href="#" style="color: #9ca3af; text-decoration: none; transition: color 0.3s; display: flex; align-items: center; gap: 8px;"><i class="fas fa-building" style="color: #dc2626; font-size: 12px;"></i> Real Estate</a></li>
                </ul>
            </div>

            <!-- Newsletter -->
            <div>
                <h3 style="color: #dc2626; font-size: 20px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                    <i class="fas fa-envelope"></i> Newsletter
                </h3>
                <p style="color: #9ca3af; margin-bottom: 15px;">Get daily market updates in your inbox!</p>
                <form style="display: flex; background: #1a1a1a; border-radius: 30px; padding: 5px; border: 1px solid #333;">
    <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                    <input type="email" placeholder="Your email" style="flex: 1; background: transparent; border: none; padding: 12px 15px; color: #ffffff; outline: none;">
